{
  "dashboard": {
    "title": "Logs Dashboard",
    "tags": ["logs", "loki"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Error Logs",
        "type": "logs",
        "targets": [
          {
            "expr": "{job=\"backend\"} |= \"error\"",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Login Failures",
        "type": "logs",
        "targets": [
          {
            "expr": "{job=\"backend\"} |= \"Login failed\"",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Validation Failures",
        "type": "logs",
        "targets": [
          {
            "expr": "{job=\"backend\"} |= \"ValidationError\"",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Log Count by Severity",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(count_over_time({job=\"backend\"}[1m])) by (level)",
            "legendFormat": "{{level}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 5,
        "title": "All Logs (Filterable by Trace ID)",
        "type": "logs",
        "targets": [
          {
            "expr": "{job=\"backend\"}",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16}
      }
    ],
    "refresh": "10s",
    "schemaVersion": 27,
    "version": 1
  }
}


