{
  "dashboard": {
    "title": "Database Performance Dashboard",
    "tags": ["database", "performance", "mysql"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Query Duration by Operation",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(db_query_duration_seconds_sum[1m]) / rate(db_query_duration_seconds_count[1m])",
            "legendFormat": "{{operation}} - {{table}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Slow Queries",
        "type": "table",
        "targets": [
          {
            "expr": "topk(10, histogram_quantile(0.95, rate(db_query_duration_seconds_bucket[5m])))",
            "format": "table",
            "legendFormat": "{{operation}} - {{table}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "DB Query Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(db_query_duration_seconds_count[1m])",
            "legendFormat": "{{operation}} - {{table}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "DB Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_errors_total{error_type=~\"Database.*\"}[1m])",
            "legendFormat": "DB Errors"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      }
    ],
    "refresh": "10s",
    "schemaVersion": 27,
    "version": 1
  }
}


